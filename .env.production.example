# MotorWa.rw - Production Environment Variables
# NEVER commit this file with real values to version control

# Database
POSTGRES_USER="motorwa"
POSTGRES_PASSWORD="<STRONG_PRODUCTION_PASSWORD>"
POSTGRES_DB="motorwa_prod"
DATABASE_URL="postgresql://motorwa:<STRONG_PRODUCTION_PASSWORD>@postgres:5432/motorwa_prod?schema=public&connection_limit=20"

# Redis
REDIS_PASSWORD="<STRONG_REDIS_PASSWORD>"
REDIS_URL="redis://:<STRONG_REDIS_PASSWORD>@redis:6379"

# Auth (generate with: openssl rand -hex 64)
JWT_SECRET="<64_CHAR_RANDOM_STRING>"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Africa's Talking (SMS)
AFRICA_TALKING_USERNAME="production_username"
AFRICA_TALKING_API_KEY="<PRODUCTION_API_KEY>"
AFRICA_TALKING_SHORTCODE="PRODUCTION_SHORTCODE"

# Cloudflare R2 (File Storage)
R2_ACCESS_KEY_ID="<R2_ACCESS_KEY>"
R2_SECRET_ACCESS_KEY="<R2_SECRET_KEY>"
R2_BUCKET_NAME="motorwa-media"
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://media.motorwa.rw"

# MTN Mobile Money (Production)
MTN_MOMO_SUBSCRIPTION_KEY="<PRODUCTION_SUBSCRIPTION_KEY>"
MTN_MOMO_API_KEY="<PRODUCTION_API_KEY>"
MTN_MOMO_TARGET_ENVIRONMENT="mtnrwanda"
MTN_MOMO_USER_ID="<PRODUCTION_USER_ID>"
MTN_MOMO_API_SECRET="<PRODUCTION_API_SECRET>"

# Airtel Money (Production)
AIRTEL_API_KEY="<PRODUCTION_API_KEY>"
AIRTEL_CLIENT_ID="<PRODUCTION_CLIENT_ID>"
AIRTEL_CLIENT_SECRET="<PRODUCTION_CLIENT_SECRET>"
AIRTEL_MERCHANT_ID="<PRODUCTION_MERCHANT_ID>"

# SendGrid (Email)
SENDGRID_API_KEY="<PRODUCTION_API_KEY>"
SENDGRID_FROM_EMAIL="hello@motorwa.rw"

# Firebase (Push Notifications)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"motorwa","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@motorwa.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# CORS
CORS_ORIGINS="https://motorwa.rw,https://www.motorwa.rw,https://admin.motorwa.rw"

# Web App
NEXT_PUBLIC_API_URL="https://motorwa.rw/api"
NEXT_PUBLIC_SITE_URL="https://motorwa.rw"

# Monitoring (optional)
SENTRY_DSN="<SENTRY_DSN>"
